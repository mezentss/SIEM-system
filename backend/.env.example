# =============================================================================
# Конфигурация SIEM Backend
# =============================================================================
# Скопируйте этот файл в .env и настройте под ваше окружение:
# cp .env.example .env

# =============================================================================
# База данных (PostgreSQL)
# =============================================================================
SIEM_DATABASE_URL=postgresql+psycopg2://siem_user:siem_password@localhost:5432/siem_db

# Настройки пула соединений
SIEM_DB_POOL_SIZE=20
SIEM_DB_MAX_OVERFLOW=10
SIEM_DB_POOL_TIMEOUT=30
SIEM_DB_POOL_RECYCLE=1800

# =============================================================================
# Приложение
# =============================================================================
SIEM_APP_NAME="SIEM Backend"
SIEM_API_PREFIX=/api
SIEM_LOG_LEVEL=INFO

# =============================================================================
# Telegram уведомления (опционально)
# =============================================================================
# SIEM_TELEGRAM_BOT_TOKEN=your_bot_token_here
# SIEM_TELEGRAM_CHAT_ID=your_chat_id_here

# =============================================================================
# Интервал анализа (в минутах)
# =============================================================================
# ANALYSIS_INTERVAL_MINUTES=5
